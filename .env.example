# LLM provider (OpenAI-compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
HEI_MODEL=gpt-4o-mini

# Memory backend: memory | sqlite | redis
HEI_MEMORY_BACKEND=memory
HEI_MEMORY_PATH=./hei_memory.db
